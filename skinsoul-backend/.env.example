# ============================================================
#  SkinSoul — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# GEMINI API Key (required)
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyAIa4UlJF38uuB4dqBoFkRJtTPYvfV2Hk8
# Server
PORT=3000
NODE_ENV=development

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry (e.g. "7d", "24h")
JWT_EXPIRES_IN=7d

# File upload limits (bytes). Default = 10 MB
MAX_FILE_SIZE=10485760

# Rate limiting — max requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AI Analysis rate limit (separate, heavier limit for Anthropic calls)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10

# OpenWeatherMap API (optional — for real UV index data)
# Get free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# CORS — comma-separated allowed origins in production
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
